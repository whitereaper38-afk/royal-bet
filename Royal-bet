let users = JSON.parse(localStorage.getItem("users")) || {};
let currentUser = localStorage.getItem("currentUser");
const adminUser = "admin";

function login(){
  let u = document.getElementById("username").value;
  if(!users[u]){
    users[u]={balance:100};
  }
  localStorage.setItem("users",JSON.stringify(users));
  localStorage.setItem("currentUser",u);
  currentUser=u;
  document.getElementById("loginMsg").innerText="Hyrja e suksesshme!";
  updateBalance();
}

function createUser(){
  let u=prompt("Shkruaj username per userin e ri:");
  if(u){
    users[u]={balance:100};
    localStorage.setItem("users",JSON.stringify(users));
    document.getElementById("adminMsg").innerText="User "+u+" u krijua!";
  }
}

function addCredits(){
  let u=document.getElementById("user").value;
  let a=parseInt(document.getElementById("amount").value);
  if(users[u]){
    users[u].balance+=a;
    localStorage.setItem("users",JSON.stringify(users));
    document.getElementById("adminMsg").innerText=a+" kredita u shtuan tek "+u;
  }
}

function updateBalance(){
  if(currentUser && users[currentUser])
    document.getElementById("balance").innerText="Balance: "+users[currentUser].balance;
}

function result(msg){document.getElementById("result").innerText=msg; save();}
function save(){localStorage.setItem("users",JSON.stringify(users)); updateBalance();}

function dice(){users[currentUser].balance+=(Math.random()>0.5?10:-10); result("Dice!");}
function coinflip(){users[currentUser].balance+=(Math.random()>0.5?10:-10); result("Coinflip!");}
function wheel(){users[currentUser].balance+=(Math.random()>0.7?20:-10); result("Wheel!");}
function slots(){users[currentUser].balance+=(Math.random()>0.8?50:-10); result("Slots!");}
function mines(){users[currentUser].balance+=(Math.random()>0.75?30:-10); result("Mines!");}
function crash(){users[currentUser].balance+=(Math.random()>0.7?40:-10); result("Crash!");}
function roulette(){users[currentUser].balance+=(Math.random()>0.5?25:-10); result("Roulette!");}
function bet(sport){users[currentUser].balance+=(Math.random()>0.5?20:-20); result("Bast "+sport+"!");}

updateBalance();
